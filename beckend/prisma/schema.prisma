generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  jogatinas    Jogatina[] 
}

model Game {
  id          Int        @id @default(autoincrement())
  title       String
  developer   String?
  jogatinas   Jogatina[] 
}

model Jogatina {
  id               Int      @id @default(autoincrement())
  userId           Int
  gameId           Int
  decisaoPrincipal String   
  finalObtido      String   
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
}